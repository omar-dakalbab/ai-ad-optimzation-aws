# ===========================================
# Amazon Ads AI - Environment Configuration
# ===========================================
# Copy this to .env and fill in your values

# --- Database ---
AAI_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/amazon_ads_ai
AAI_REDIS_URL=redis://localhost:6379/0

# --- Amazon Ads API ---
# Get these from https://advertising.amazon.com/API/docs
AAI_AMAZON_ADS_CLIENT_ID=your_client_id
AAI_AMAZON_ADS_CLIENT_SECRET=your_client_secret
AAI_AMAZON_ADS_REFRESH_TOKEN=your_refresh_token
AAI_AMAZON_ADS_PROFILE_ID=your_profile_id
AAI_AMAZON_ADS_REGION=NA

# --- Amazon SP-API ---
# Get these from https://developer-docs.amazon.com/sp-api/
AAI_SP_API_REFRESH_TOKEN=your_sp_api_refresh_token
AAI_SP_API_LWA_APP_ID=your_lwa_app_id
AAI_SP_API_LWA_CLIENT_SECRET=your_lwa_client_secret
AAI_SP_API_AWS_ACCESS_KEY=your_aws_access_key
AAI_SP_API_AWS_SECRET_KEY=your_aws_secret_key
AAI_SP_API_ROLE_ARN=arn:aws:iam::123456789:role/your-role
AAI_MARKETPLACE_ID=ATVPDKIKX0DER

# --- Optimization Settings ---
AAI_TARGET_ACOS=0.25
AAI_MIN_ROAS=3.0
AAI_DRY_RUN=true

# --- MLflow ---
AAI_MLFLOW_TRACKING_URI=http://localhost:5000
